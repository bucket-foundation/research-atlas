# Raw source caches (idempotent re-downloads -- never commit)
data/raw/

# DuckDB build artifact (rebuilt from parquet)
*.duckdb
*.duckdb.wal

# Large processed parquet -- commit only small published samples.
# Sample datasets are force-added explicitly (see scripts/commit_sample.sh).
data/processed/*.parquet
!data/processed/sample/*.parquet

# Ranking system: heavy corpus + per-work ranking parquet (rebuilt from the
# OpenAlex cache). The small committed slice lives under data/processed/sample/.
data/processed/ranking/*.parquet

# Cross-field orchestrator: commit the checkpoint JSONs + manifest + convergence
# log (small, durable results), but NOT the run lock, transient partials, or
# the run log (all rebuilt by re-running scripts/crossfield_run.py).
analysis/crossfield/run.lock
analysis/crossfield/*.partial.json
analysis/crossfield/*.tmp
analysis_ckpt*.log

# PII-BEARING researcher/users CRM table -- carries harvested PUBLIC emails.
# NEVER commit. Only the email-free sample + aggregates ship (see
# scripts/build_users_sample.py and docs/USERS_POLICY.md). Listed explicitly
# (belt-and-suspenders on top of the data/processed/*.parquet rule above).
data/processed/researchers.parquet
data/processed/users.parquet
# Raw contact-lookup cache (ORCID / EuropePMC responses) may contain emails.
data/raw/contacts/

# Partitioned shard directories written by the bulk scale path
# (data/processed/<table>/source=.../year=.../part-*.parquet). Rebuilt from raw
# via scripts/ingest_*.py + scripts/consolidate.py; never committed.
data/processed/funder/
data/processed/grant/
data/processed/organization/
data/processed/person/
data/processed/work/
data/processed/field/
data/processed/funder_grant/
data/processed/grant_org/
data/processed/grant_person/
data/processed/grant_work/
data/processed/person_org/
data/processed/work_field/

# Secrets / env
.env
.env.*
*.pem
*.key
secrets/
credentials.json

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/
build/
dist/

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/
